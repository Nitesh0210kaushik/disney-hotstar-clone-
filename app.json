{
  "expo": {
    "name": "Disney+ Hotstar Clone",
    "slug": "disney-hotstar-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hotstar-app-icon.png",
    "scheme": "disneyhotstarclone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/hotstar-app-icon.png"
    },
    "androidStatusBar": {
      "backgroundColor": "#F5F7FB",
      "barStyle": "dark-content",
      "translucent": false
    },
    "android": {
      "package": "com.niteshkaushik.disneyhotstarclone",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/hotstar-app-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/hotstar-app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F7FB",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65341bc7-3cd5-4e85-b762-1c658f2da2fc"
      }
    },
    "owner": "niteshkaushik0210"
  }
}
